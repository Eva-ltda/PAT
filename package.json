{
  "name": "dashboard-arduino-scada",
  "private": true,
  "version": "1.0.0",
  "description": "Dashboard industrial premium em tempo real para Arduino UNO (Electron + React + Tailwind + Serial + Socket.IO).",
  "main": "electron/main.cjs",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "build:win": "npm run build:renderer && electron-builder --win",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@serialport/parser-readline": "^13.0.0",
    "framer-motion": "^12.23.6",
    "lucide-react": "^0.525.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^2.15.4",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^42.0.1",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.4",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.pat.dashboardarduino",
    "productName": "Dashboard Arduino",
    "icon": "build/icon.png",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
